@model Teste_Codificar.Models.Chamado

@{
    ViewData["Title"] = "Novo Chamado";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h1>Novo Chamado</h1>
        <h5 class="text-muted">
            Preencha as informações para abrir um novo chamado
        </h5>
    </div>

    <a asp-action="Index" class="btn btn-secondary">
        Voltar para Lista
    </a>

</div>

<div class="card">

    <div class="card-header">
        <h4>Dados do Chamado</h4>
    </div>

    <div class="card-body">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger">
            </div>

            <div class="mb-3">
                <label asp-for="Titulo" class="form-label">
                    Título
                </label>

                <input asp-for="Titulo"
                       class="form-control" />

                <span asp-validation-for="Titulo"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="Descricao" class="form-label">
                    Descrição
                </label>

                <textarea asp-for="Descricao"
                          class="form-control"
                          rows="4"></textarea>

                <span asp-validation-for="Descricao"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="Prioridade" class="form-label">
                    Prioridade
                </label>

                <select asp-for="Prioridade"
                        class="form-select"
                        asp-items="Html.GetEnumSelectList<Prioridade>()">
                </select>

                <span asp-validation-for="Prioridade"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label">
                    Status
                </label>

                <select asp-for="Status"
                        class="form-select"
                        asp-items="Html.GetEnumSelectList<StatusChamado>()">
                </select>

                <span asp-validation-for="Status"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="ResponsavelId"
                       class="form-label">
                    Responsável
                </label>

                <select asp-for="ResponsavelId"
                        class="form-select"
                        asp-items="ViewBag.Responsaveis">

                    <option value="">
                        Selecione um responsável
                    </option>

                </select>

                <span asp-validation-for="ResponsavelId"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="DataAbertura"
                       class="form-label">
                    Data de Abertura
                </label>

                <input asp-for="DataAbertura"
                       class="form-control" />

                <span asp-validation-for="DataAbertura"
                      class="text-danger">
                </span>
            </div>

            <hr />

            <button type="submit"
                    class="btn btn-success">
                Criar Chamado
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Cancelar
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}