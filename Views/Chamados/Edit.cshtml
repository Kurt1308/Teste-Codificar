@model Teste_Codificar.Models.Chamado

@{
    ViewData["Title"] = "Editar Chamado";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h1>Editar Chamado</h1>
        <h5 class="text-muted">
            Atualize as informaēões do chamado
        </h5>
    </div>

    <a asp-action="Index" class="btn btn-secondary">
        Voltar para Lista
    </a>

</div>

<div class="card">

    <div class="card-header">
        <h4>Dados do Chamado</h4>
    </div>

    <div class="card-body">

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger">
            </div>

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Titulo" class="form-label">
                    Tķtulo
                </label>
                <input asp-for="Titulo" class="form-control" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descricao" class="form-label">
                    Descriēćo
                </label>
                <textarea asp-for="Descricao"
                          class="form-control"
                          rows="4"></textarea>
                <span asp-validation-for="Descricao" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Prioridade" class="form-label">
                    Prioridade
                </label>
                <select asp-for="Prioridade" class="form-select">
                    <option value="1">Baixa</option>
                    <option value="2">Média</option>
                    <option value="3">Alta</option>
                </select>
                <span asp-validation-for="Prioridade" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label">
                    Status
                </label>
                <select asp-for="Status" class="form-select">
                    <option value="1">Aberto</option>
                    <option value="2">Em Andamento</option>
                    <option value="3">Resolvido</option>
                    <option value="4">Fechado</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ResponsavelId" class="form-label">
                    Responsįvel
                </label>

                <select asp-for="ResponsavelId"
                        asp-items="ViewBag.Responsaveis"
                        class="form-select">
                    <option value="">
                        Selecione um responsįvel
                    </option>
                </select>

                <span asp-validation-for="ResponsavelId"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="DataAbertura" class="form-label">
                    Data de Abertura
                </label>

                <input asp-for="DataAbertura"
                       class="form-control" />

                <span asp-validation-for="DataAbertura"
                      class="text-danger">
                </span>
            </div>

            <hr />

            <button type="submit"
                    class="btn btn-primary">
                Salvar Alteraēões
            </button>

            <a asp-action="Details"
               asp-route-id="@Model.Id"
               class="btn btn-info text-white">
                Detalhes
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}