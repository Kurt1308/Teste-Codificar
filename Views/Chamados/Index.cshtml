@model IEnumerable<Teste_Codificar.Models.Chamado>

@{
    ViewData["Title"] = "Chamados";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h1>Chamados</h1>
        <h5 class="text-muted">
            Gerenciamento e acompanhamento de chamados
        </h5>
    </div>

    <a asp-action="Create" class="btn btn-success">
        + Novo Chamado
    </a>

</div>

<div class="card">

    <div class="card-header">
        <h4>Lista de Chamados</h4>
    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table class="table table-striped table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Título</th>
                        <th>Descrição</th>
                        <th>Prioridade</th>
                        <th>Status</th>
                        <th>Responsável</th>
                        <th>Data de Abertura</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.Titulo
                            </td>

                            <td>
                                @(item.Descricao.Length > 50
                                    ? item.Descricao.Substring(0, 50) + "..."
                                    : item.Descricao)
                            </td>

                            <td>
                                @item.Prioridade
                            </td>

                            <td>
                                @item.Status
                            </td>

                            <td>
                                @item.Responsavel?.Nome
                            </td>

                            <td>
                                @item.DataAbertura.ToString("dd/MM/yyyy HH:mm")
                            </td>

                            <td class="text-center">

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm text-white">
                                    Detalhes
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary btn-sm">
                                    Editar
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">
                                    Excluir
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>